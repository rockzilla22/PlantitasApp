# =============================================================================
# TEMPLATE_FRONTEND_NEXT_JF - MANIFIESTO DE INFRAESTRUCTURA (.env.example)
# =============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env.local.
# 2. No compartas valores reales. Jarvis tiene prohibido leer .env para evitar fugas.
# 3. Todo secreto DEBE permanecer sin el prefijo NEXT_PUBLIC_.
# =============================================================================

# --- CORE INFRASTRUCTURE (SITE & AUTH) ---
# URL canónica necesaria para generación de sitemaps y metadatos SEO.
SITE_URL=http://localhost:3000

# NextAuth Configuration
# Generar secreto con: 'openssl rand -base64 32'
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- DATABASE & PERSISTENCE ---
# Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# --- EXTERNAL SERVICES (BACKEND ONLY / SECRETS) ---

# AI Engine API Keys
CLAUDE_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# OAuth Providers (OAuth 2.0)
GITHUB_ID=
GITHUB_SECRET=
DISCORD_ID=
DISCORD_SECRET=
FACEBOOK_ID=
FACEBOOK_SECRET=
TWITTER_ID=
TWITTER_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=
LINKEDIN_ID=
LINKEDIN_SECRET=

# Email Delivery (Resend)
RESEND_API_KEY=

# Payments Infrastructure (Secret Keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
MERCADOPAGO_PRIVATE_KEY=

# Fiscal Infrastructure (Mexico SAT)
FACTURA_GREEN_API_KEY=
FACTURA_GREEN_BUSINESS_UUID=
FACTURA_GREEN_ACCOUNT_UUID=

# --- UI CONFIGURATION & TELEMETRY (PUBLIC / HUD) ---
# NOTA: Estas variables se inyectan en el bundle de cliente. 

# Analytics & Behavior Tracking
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_CRISP_ID=

# Stripe Public Configuration
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Metadata & Branding
NEXT_PUBLIC_APP_NAME=Template_FrontEnd_Next_JF
NEXT_PUBLIC_APP_DESCRIPTION=
NEXT_PUBLIC_DOMAIN_NAME=

# Theme & DaisyUI
NEXT_PUBLIC_DAISY_THEME=dark

# Auth UI Routes
# Nombre sincronizado con la implementación en src/libs/api.ts
NEXT_PUBLIC_LOGIN_URL=/auth/signin
NEXT_PUBLIC_AUTH_CALLBACK_URL=/dashboard

# --- ASSETS & STORAGE (CDN) ---
NEXT_PUBLIC_AWS_BUCKET=
NEXT_PUBLIC_AWS_BUCKET_URL=
NEXT_PUBLIC_AWS_CDN=

# --- STRIPE PRICE CATALOG (METADATA) ---
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_ADVANCED=

# Starter Plan Metadata (UI Only)
NEXT_PUBLIC_STRIPE_PLAN_STARTER_NAME=
NEXT_PUBLIC_STRIPE_PLAN_STARTER_DESCRIPTION=
NEXT_PUBLIC_STRIPE_PLAN_STARTER_PRICE=
NEXT_PUBLIC_STRIPE_PLAN_STARTER_ANCHOR=
NEXT_PUBLIC_STRIPE_PLAN_STARTER_FEATURE_1=

# Advanced Plan Metadata (UI Only)
NEXT_PUBLIC_STRIPE_PLAN_ADVANCED_NAME=
NEXT_PUBLIC_STRIPE_PLAN_ADVANCED_DESCRIPTION=
NEXT_PUBLIC_STRIPE_PLAN_ADVANCED_PRICE=
NEXT_PUBLIC_STRIPE_PLAN_ADVANCED_ANCHOR=
NEXT_PUBLIC_STRIPE_PLAN_ADVANCED_FEATURE_1=

# --- EMAIL SENDER (UI) ---
NEXT_PUBLIC_RESEND_FROM_NO_REPLY=
NEXT_PUBLIC_RESEND_FROM_ADMIN=
NEXT_PUBLIC_RESEND_SUPPORT_EMAIL=